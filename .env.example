###############################################################################
#  Parrot Canada Visa Consultant — Backend CMS
#  cPanel / Shared Hosting deployment template
#  Copy this file to `.env` on the server and fill the real values.
###############################################################################

# --- Application -------------------------------------------------------------
APP_ENV=production
DEBUG=false

SITE_URL=https://visaconsultantcanada.com/backend/
SITE_NAME=Parrot Canada Visa Consultant - Admin
ADMIN_EMAIL=infos@visaconsultantcanada.com

# Public website (Next.js front-end) — used in CORS + email links.
FRONTEND_URL=https://visaconsultantcanada.com

# --- Database (CMS) ----------------------------------------------------------
# On cPanel create the DB + user in "MySQL Databases" first, then assign the
# user to the DB with ALL PRIVILEGES. The CMS will auto-create its tables
# (menu_items, eligible_programs_settings, gallery_images, …) on first request.
DB_HOST=localhost
DB_NAME=visaeofi_web
DB_USER=visaeofi_web_user
DB_PASS=Petero@1981

# --- Smart Brochure source (parrot_mis) -------------------------------------
# The Eligible Programs feature reads brochures cross-DB from the parrot_mis
# install. IMPORTANT for cPanel: the DB_USER above MUST also be assigned to
# this database (cPanel → MySQL Databases → "Add User To Database").
# The DB name on cPanel is prefixed with your account, e.g. visaeofi_mis_parrot.
PARROT_MIS_DB=visaeofi_mis_parrot
PARROT_MIS_PUBLIC_URL=https://mis.visaconsultantcanada.com/

# --- CORS (comma separated origins) -----------------------------------------
CORS_ALLOWED_ORIGINS=https://visaconsultantcanada.com,https://www.visaconsultantcanada.com

# --- Security ----------------------------------------------------------------
# Generate fresh random strings for production. Examples:
#   openssl rand -hex 32   (Linux/Mac)
#   php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS_RANDOM_STRING_FOR_JWT_SIGNING_PRODUCTION
APP_KEY=CHANGE_ME_64_HEX_CHARS_RANDOM_APP_ENCRYPTION_KEY_FOR_PRODUCTION
HASH_ALGO=PASSWORD_DEFAULT
BCRYPT_COST=12
SESSION_LIFETIME=3600

FORCE_HTTPS=true
SECURITY_HEADERS_ENABLED=true

# --- Uploads -----------------------------------------------------------------
# Path is relative to the backend folder. cPanel default works as-is.
UPLOAD_PATH=public/backend/uploads/
MAX_FILE_SIZE=5242880

# --- External API Keys (optional) -------------------------------------------
# STRIPE_API_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# GOOGLE_MAPS_API_KEY=xxx
# EMAIL_API_KEY=xxx

###############################################################################
#  cPanel deployment checklist
#  ---------------------------------------------------------------------------
#  1. Upload the entire `backend/` folder to public_html/backend (or subdomain
#     root). Ensure `.env` exists with the values above (don't commit it).
#  2. cPanel → MySQL Databases:
#       - Create DB: visaeofi_web  (matches DB_NAME)
#       - Create User: visaeofi_web_user with a strong password
#       - Add User to BOTH `visaeofi_web` and `visaeofi_mis_parrot` with
#         ALL PRIVILEGES (required for cross-DB brochure read).
#  3. Visit https://visaconsultantcanada.com/backend/ once — tables auto-create:
#       parrot_visa_cms tables:  menu_items, eligible_programs_settings,
#                                gallery_images, settings, …
#       cross-DB on parrot_mis:  marketing_brochures.university_id column
#                                added automatically when missing.
#  4. Run https://visaconsultantcanada.com/backend/setup-admin.php once to
#     create the default admin (then delete that file).
#  5. Frontend (Next.js) .env.local on the front-end host:
#       NEXT_PUBLIC_BACKEND_URL=https://visaconsultantcanada.com/backend
###############################################################################
