# Database Configuration
DB_HOST=localhost
DB_NAME=parrot_visa_cms
DB_USER=root
DB_PASS=

# Site Configuration
SITE_URL=http://localhost/backend/
SITE_NAME=Parrot Canada Visa Consultant - Admin
ADMIN_EMAIL=admin@parrotvisa.com

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
APP_KEY=your_app_key_here_change_this_in_production
HASH_ALGO=PASSWORD_DEFAULT
BCRYPT_COST=12

# Upload Configuration
UPLOAD_PATH=public/backend/uploads/
MAX_FILE_SIZE=5242880
SESSION_LIFETIME=3600

# API Keys (add your external API keys here)
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
EMAIL_API_KEY=your_email_service_key_here

# Development/Production
APP_ENV=development
DEBUG=true
